VITE_SUPABASE_URL=https://your-project.supabase.co
VITE_SUPABASE_ANON_KEY=your-anon-key-here
# Web Push VAPID public key (npx web-push generate-vapid-keys). Public — safe to expose.
VITE_VAPID_PUBLIC_KEY=your-vapid-public-key

# Server-side only (set in Vercel dashboard, NOT prefixed with VITE_)
# OPENAI_API_KEY=sk-...
# SUPABASE_URL=https://your-project.supabase.co
# SUPABASE_SERVICE_ROLE_KEY=your-service-role-key
#
# Edge Function secrets (set via Supabase, NOT here) for send-push:
#   PUSH_WEBHOOK_SECRET, VAPID_PUBLIC_KEY, VAPID_PRIVATE_KEY, VAPID_SUBJECT,
#   APNS_KEY_ID, APNS_TEAM_ID, APNS_BUNDLE_ID, APNS_PRIVATE_KEY (.p8 contents)
